{
  "name": "job-tracker-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.mjs",
    "start": "node src/index.mjs",
    "migrate": "node src/db/migrate.mjs",
    "migrate:undo": "node src/db/migrate.mjs --undo",
    "seed": "node src/db/seed.mjs",
    "db:reset": "node src/db/migrate.mjs --reset && node src/db/seed.mjs"
  },
  "dependencies": {
    "@node-rs/bcrypt": "^1.10.7",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  }
}
