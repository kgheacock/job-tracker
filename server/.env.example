# Database
DATABASE_URL=postgres://job_tracker:job_tracker_dev@localhost:5432/job_tracker

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
