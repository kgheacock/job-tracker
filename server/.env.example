# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# OTel (optional in dev — comment out to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=job-tracker-api

